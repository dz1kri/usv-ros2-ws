#!/usr/bin/env python3
import rclpy
from rclpy.node import Node
from geometry_msgs.msg import PoseStamped
from std_msgs.msg import Float64
import requests
import json
import subprocess
import math
import ssl
from datetime import datetime
import paho.mqtt.client as mqtt

class SeanoCloudBridge(Node):
    def __init__(self):
        super().__init__('seano_cloud_bridge')
        
        # ==================== CONFIGURATION ====================
        # API Configuration
        self.api_base_url = 'https://api.seano.cloud'
        self.vehicle_id = None  # Will be set after registration
        self.vehicle_name = 'USV_Gazebo_Simulator'
        
        # MQTT Configuration
        self.mqtt_broker = 'd7b48187457f4e799b84ef68d8cf8783.s1.eu.hivemq.cloud'
        self.mqtt_port = 8884
        self.mqtt_username = 'seanoraspi'
        self.mqtt_password = 'Seanoraspi24*'
        
        # Auth token (you need to login first)
        self.auth_token = None
        
        # ==================== STATE VARIABLES ====================
        self.current_pose = None
        self.current_mission = None
        self.current_waypoint_index = 0
        self.mission_active = False
        
        # ==================== ROS SUBSCRIBERS ====================
        self.pose_sub = self.create_subscription(
            PoseStamped,
            '/wamv/pose',
            self.pose_callback,
            10
        )
        
        # ==================== MQTT SETUP ====================
        self.setup_mqtt()
        
        # ==================== TIMERS ====================
        self.telemetry_timer = self.create_timer(2.0, self.send_telemetry_http)
        self.mission_timer = self.create_timer(3.0, self.check_mission)
        self.navigation_timer = self.create_timer(0.1, self.navigate)
        
        self.get_logger().info('=' * 70)
        self.get_logger().info('🌊 SEANO Cloud Bridge Started!')
        self.get_logger().info(f'🌐 API: {self.api_base_url}')
        self.get_logger().info(f'📡 MQTT: {self.mqtt_broker}:{self.mqtt_port}')
        self.get_logger().info('=' * 70)
        
        # Login and register vehicle
        self.login()
        self.register_vehicle()
    
    def setup_mqtt(self):
        """Setup MQTT client for real-time telemetry"""
        self.mqtt_client = mqtt.Client(
            client_id=f"usv_gazebo_{self.vehicle_name}", 
            clean_session=True
        )
        self.mqtt_client.username_pw_set(self.mqtt_username, self.mqtt_password)
        
        # TLS/SSL setup
        self.mqtt_client.tls_set(
            cert_reqs=ssl.CERT_REQUIRED,
            tls_version=ssl.PROTOCOL_TLSv1_2
        )
        self.mqtt_client.tls_insecure_set(False)
        
        # Callbacks
        self.mqtt_client.on_connect = self.on_mqtt_connect
        self.mqtt_client.on_disconnect = self.on_mqtt_disconnect
        self.mqtt_client.on_message = self.on_mqtt_message
        
        # Enable automatic reconnection
        self.mqtt_client.reconnect_delay_set(min_delay=1, max_delay=120)
        
        try:
            self.mqtt_client.connect(
                self.mqtt_broker, 
                self.mqtt_port, 
                keepalive=120
            )
            self.mqtt_client.loop_start()
            self.get_logger().info('✅ MQTT connected')
        except Exception as e:
            self.get_logger().error(f'❌ MQTT connection failed: {e}')
    
    def on_mqtt_connect(self, client, userdata, flags, rc):
        """MQTT connection callback"""
        if rc == 0:
            self.get_logger().info('✅ MQTT connection successful')
            # Subscribe to mission topics
            client.subscribe(f'vehicle/{self.vehicle_id}/mission/#')
            client.subscribe('mission/broadcast/#')
        else:
            self.get_logger().error(f'❌ MQTT connection failed with code: {rc}')
    
    def on_mqtt_disconnect(self, client, userdata, rc):
        """MQTT disconnection callback"""
        self.get_logger().warn('⚠️ MQTT disconnected')

   def on_mqtt_message(self, client, userdata, msg):
    """MQTT message callback"""
    try:
        payload = json.loads(msg.payload.decode())
        self.get_logger().info(f'📨 MQTT message on {msg.topic}: {payload}')
    except Exception as e:
        self.get_logger().debug(f'MQTT message parse error: {e}')
    
    def login(self):
        """Login to SEANO API - YOU NEED TO SET YOUR CREDENTIALS HERE"""
        try:
            # TODO: Set your email and password
            login_data = {
                'email': 'seanouser@gmail.com',  # GANTI INI!
                'password': 'Seano2025*'  # GANTI INI!
            }
            
            response = requests.post(
                f'{self.api_base_url}/auth/login',
                json=login_data,
                timeout=10
            )
            
            if response.status_code == 200:
                data = response.json()
                self.auth_token = data.get('token') or data.get('access_token')
                self.get_logger().info('✅ Login successful')
                return True
            else:
                self.get_logger().error(f'❌ Login failed: {response.status_code}')
                self.get_logger().error(f'Response: {response.text}')
                return False
                
        except Exception as e:
            self.get_logger().error(f'❌ Login error: {e}')
            return False
    
    def get_headers(self):
        """Get HTTP headers with auth token"""
        headers = {
            'Content-Type': 'application/json'
        }
        if self.auth_token:
            headers['Authorization'] = f'Bearer {self.auth_token}'
        return headers
    
    def register_vehicle(self):
        """Register vehicle with SEANO"""
        try:
            vehicle_data = {
                'name': self.vehicle_name,
                'type': 'USV',
                'description': 'Gazebo Simulator Vehicle',
                'status': 'active'
            }
            
            response = requests.post(
                f'{self.api_base_url}/vehicles/',
                json=vehicle_data,
                headers=self.get_headers(),
                timeout=10
            )
            
            if response.status_code in [200, 201]:
                data = response.json()
                self.vehicle_id = data.get('id')
                self.get_logger().info(f'✅ Vehicle registered: ID = {self.vehicle_id}')
            else:
                self.get_logger().warn(f'⚠️ Vehicle registration failed: {response.status_code}')
                # Try to get existing vehicle
                self.get_existing_vehicle()
                
        except Exception as e:
            self.get_logger().error(f'❌ Vehicle registration error: {e}')
    
    def get_existing_vehicle(self):
        """Get existing vehicle by name"""
        try:
            response = requests.get(
                f'{self.api_base_url}/vehicles/',
                headers=self.get_headers(),
                timeout=10
            )
            
            if response.status_code == 200:
                vehicles = response.json()
                for vehicle in vehicles:
                    if vehicle.get('name') == self.vehicle_name:
                        self.vehicle_id = vehicle.get('id')
                        self.get_logger().info(f'✅ Using existing vehicle: ID = {self.vehicle_id}')
                        return
                        
        except Exception as e:
            self.get_logger().error(f'❌ Error getting vehicles: {e}')
    
    def pose_callback(self, msg):
        """Handle pose updates from ROS"""
        self.current_pose = msg
    
    def send_telemetry_http(self):
        """Send telemetry via HTTP POST"""
        if self.current_pose is None or self.vehicle_id is None:
            return
        
        try:
            x = self.current_pose.pose.position.x
            y = self.current_pose.pose.position.y
            z = self.current_pose.pose.position.z
            
            # Convert meters to lat/lon (adjust for your coordinate system)
            latitude = y / 111320.0
            longitude = x / (111320.0 * math.cos(math.radians(latitude)))
            
            telemetry = {
                'vehicle_id': self.vehicle_id,
                'timestamp': datetime.utcnow().isoformat() + 'Z',
                'latitude': latitude,
                'longitude': longitude,
                'altitude': z,
                'heading': 0.0,
                'speed': 0.0,
                'battery_percentage': 100
            }
            
            # Send via HTTP
            response = requests.post(
                f'{self.api_base_url}/vehicle-logs/',
                json=telemetry,
                headers=self.get_headers(),
                timeout=2
            )
            
            if response.status_code in [200, 201]:
                self.get_logger().debug('✅ Telemetry sent (HTTP)')
            
            # Also send via MQTT for real-time
            self.send_telemetry_mqtt(telemetry)
                
        except Exception as e:
            self.get_logger().debug(f'Telemetry error: {e}')
    
    def send_telemetry_mqtt(self, telemetry):
        """Send telemetry via MQTT"""
        if self.vehicle_id:
            try:
                topic = f'vehicle/{self.vehicle_id}/telemetry'
                payload = json.dumps(telemetry)
                self.mqtt_client.publish(topic, payload)
                self.get_logger().debug('✅ Telemetry sent (MQTT)')
            except Exception as e:
                self.get_logger().debug(f'MQTT publish error: {e}')
    
    def check_mission(self):
        """Check for active missions"""
        if self.vehicle_id is None:
            return
        
        try:
            response = requests.get(
                f'{self.api_base_url}/missions/ongoing',
                headers=self.get_headers(),
                timeout=5
            )
            
            if response.status_code == 200:
                missions = response.json()
                
                # Find mission for this vehicle
                for mission in missions:
                    if mission.get('vehicle_id') == self.vehicle_id:
                        if mission.get('id') != (self.current_mission.get('id') if self.current_mission else None):
                            self.current_mission = mission
                            self.current_waypoint_index = 0
                            self.mission_active = True
                            
                            waypoints = mission.get('waypoints', [])
                            self.get_logger().info(f'🗺️ New mission: {mission.get("name")}')
                            self.get_logger().info(f'📍 Waypoints: {len(waypoints)}')
                        break
                        
        except Exception as e:
            self.get_logger().debug(f'Mission check error: {e}')
    
    def navigate(self):
        """Execute waypoint navigation"""
        if not self.mission_active or not self.current_mission or self.current_pose is None:
            return
        
        waypoints = self.current_mission.get('waypoints', [])
        
        if self.current_waypoint_index >= len(waypoints):
            self.get_logger().info('✅ Mission completed!')
            self.mission_active = False
            self.send_thrust(0.0, 0.0)
            self.update_mission_progress(100)
            return
        
        wp = waypoints[self.current_waypoint_index]
        target_lat = wp.get('latitude', 0)
        target_lon = wp.get('longitude', 0)
        
        # Convert to meters
        target_x = target_lon * 111320.0 * math.cos(math.radians(target_lat))
        target_y = target_lat * 111320.0
        
        current_x = self.current_pose.pose.position.x
        current_y = self.current_pose.pose.position.y
        
        dx = target_x - current_x
        dy = target_y - current_y
        distance = math.sqrt(dx**2 + dy**2)
        
        if distance < 2.0:
            self.get_logger().info(f'✅ Waypoint {self.current_waypoint_index + 1}/{len(waypoints)} reached!')
            self.current_waypoint_index += 1
            
            # Update progress
            progress = int((self.current_waypoint_index / len(waypoints)) * 100)
            self.update_mission_progress(progress)
            return
        
        thrust = min(distance * 10.0, 50.0)
        self.send_thrust(thrust, thrust)
    
    def update_mission_progress(self, progress):
        """Update mission progress to SEANO"""
        if not self.current_mission:
            return
        
        try:
            mission_id = self.current_mission.get('id')
            requests.put(
                f'{self.api_base_url}/missions/{mission_id}/progress',
                json={'progress': progress},
                headers=self.get_headers(),
                timeout=2
            )
        except Exception as e:
            self.get_logger().debug(f'Progress update error: {e}')
    
    def send_thrust(self, left, right):
        """Send thrust commands to Gazebo"""
        try:
            subprocess.Popen([
                'gz', 'topic', '-t',
                '/model/wam-v/joint/left_propeller_joint/cmd_thrust',
                '-m', 'gz.msgs.Double', '-p', f'data: {left}'
            ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            
            subprocess.Popen([
                'gz', 'topic', '-t',
                '/model/wam-v/joint/right_propeller_joint/cmd_thrust',
                '-m', 'gz.msgs.Double', '-p', f'data: {right}'
            ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except Exception as e:
            self.get_logger().error(f'Thrust error: {e}')
    
    def __del__(self):
        """Cleanup"""
        if hasattr(self, 'mqtt_client'):
            self.mqtt_client.loop_stop()
            self.mqtt_client.disconnect()

def main(args=None):
    rclpy.init(args=args)
    node = SeanoCloudBridge()
    
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        node.get_logger().info('Shutting down...')
    
    node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__':
    main()
